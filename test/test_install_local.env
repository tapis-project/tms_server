# Settings for testing install on local host.
#
export TMS_ROOT_DIR=~/.tms
export TMS_LOCAL_DIR=~/.tms/local
export TMS_INSTALL_DIR=/tmp/tms_server

export POSTGRES_PASSWORD=password
export TMS_DB_USER_PASSWORD=password

export TMS_DB_HOST=localhost
export TMS_DB_PORT=5431

# Paths to SSL cert and key
export TMS_SSL_CERT_PATH=$HOME/tms_server/resources/certs/cert.pem
export TMS_SSL_KEY_PATH=$HOME/tms_server/resources/certs/key.pem