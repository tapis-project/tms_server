# Needed for drop and init of postgres DB
export POSTGRES_PASSWORD=password

# TMS_HOME not used, but might make sense to have this. This is not where executable is installed.
export TMS_HOME=~/.tms

# Used to override the default value used during upgrade
export TMS_INSTALL_DIR=/tmp/tms_server

# Example db_url = postgres://tms:password@localhost:5431/tmsdb
# Only required DB config parameter is TMS_DB_USER_PASSWORD
export TMS_DB_USER_PASSWORD=password
# Port is non-default, others are the default
export TMS_DB_HOST=localhost
export TMS_DB_PORT=5431
export TMS_DB_USER=tms
