# Settings for testing install on tms-server-dev.tacc.utexas.edu
#
export POSTGRES_PASSWORD=password
export TMS_DB_USER_PASSWORD=password

# Paths to SSL cert and key
export TMS_SSL_CERT_PATH=/etc/letsencrypt/live/tms-server-dev.tacc.utexas.edu/fullchain.pem
export TMS_SSL_KEY_PATH=/etc/letsencrypt/live/tms-server-dev.tacc.utexas.edu/privkey.pem