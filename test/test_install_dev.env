# Settings for testing install on tms-server-dev.tacc.utexas.edu
#
# Use defaults
#export TMS_ROOT_DIR=~tms/.tms
#export TMS_LOCAL_DIR=~tms/.tms/local
#export TMS_INSTALL_DIR=/opt/tms_server

export POSTGRES_PASSWORD=password
export TMS_DB_USER_PASSWORD=password

# Use defaults
#export TMS_DB_HOST=localhost
#export TMS_DB_PORT=5432

# Paths to SSL cert and key
export TMS_SSL_CERT_PATH=/etc/letsencrypt/live/tms-server-dev.tacc.utexas.edu/fullchain2.pem
export TMS_SSL_KEY_PATH=/etc/letsencrypt/live/tms-server-dev.tacc.utexas.edu/privkey2.pem