# NOTE: root, install and local directories are hard-coded in the test*.sh scripts.
# TMS_ROOT_DIR is where the configuration and log files live. Default is ~/.tms
# export TMS_ROOT_DIR=~/.tms
#
# TMS_INSTALL_DIR is where the exec and version files live. Default is /opt/tms_server
# export TMS_INSTALL_DIR=/tmp/tms_server
#
# TMS_LOCAL_DIR used for install output and custom tms.toml, log4rs.yml files. Default is $TMS_ROOT_DIR/local
# export TMS_LOCAL_DIR=~/.tms/local
#

# Needed for drop and init of postgres DB
export POSTGRES_PASSWORD=password
# Example db_url = postgres://tms:password@localhost:5431/tmsdb
# Only required DB config parameter is TMS_DB_USER_PASSWORD
export TMS_DB_USER_PASSWORD=password
# Port is non-default, others are the default
export TMS_DB_PORT=5431

export TMS_INSTALL_DIR=/tmp/tms_server
